  },
  "ntp": true,
  "packages": [
    "firefox"
  ],
  "profile_config": {
    "gfx_driver": "All open-source",
    "greeter": "lightdm-gtk-greeter",
    "profiles": [
      {
        "custom_settings": {
          "Hyprland": {
            "seat_access": "polkit"
          },
          "Sway": {
            "seat_access": "seatd"
          }
        },
        "details": [
          "Sway",
          "Hyprland"
        ],
        "main": "Desktop"
      }
    ]
  },
  "custom_commands": [
