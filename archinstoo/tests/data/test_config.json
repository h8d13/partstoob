  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US",
    "console_font": "ter-v16b"
  },
  "pacman_config": {
    "custom_servers": [
        {
          "url": "https://mymirror.com/$repo/os/$arch"
        }
    ],
    "mirror_regions": {
      "Australia": [
        "http://archlinux.mirror.digitalpacific.com.au/$repo/os/$arch"
      ]
    },
    "optional_repositories": [
      "testing"
    ],
    "custom_repositories": [
      {
        "name": "myrepo",
        "url": "https://myrepo.com/$repo/os/$arch",
        "sign_check": "Required",
        "sign_option": "TrustAll"
      }
    ],
    "parallel_downloads": 66
  },
  "network_config": {
    "type": "manual",
    "nics": [
      {
        "iface": "eno1",
        "ip": "192.168.1.15/24",
        "dhcp": true,
        "gateway": "192.168.1.1",
        "dns": [
          "192.168.1.1",
          "9.9.9.9"
