{
  "archinstall-language": "English",
  "script": "guided",
  "app_config": {
      "bluetooth_config": {
          "enabled": true
      },
      "audio_config": {
          "audio": "pipewire"
      },
      "print_service_config": {
          "enabled": true
      },
      "firewall_config": {
          "firewall": "ufw"
      },
      "management_config": {
          "tools": ["git", "man-db"]
      },
      "monitor_config": {
          "monitor": "htop"
      },
      "editor_config": {
          "editor": "vim"
      },
      "power_management_config": {
          "power_management": "power-profiles-daemon"
      },
      "security_config": {
          "tools": ["apparmor", "firejail"]
      }
  },
  "auth_config": {
      "root_enc_password": "__RHASH__",
