# shell.nix
# Usage: nix-shell NIX
{ pkgs ? import <nixpkgs> {} }:

pkgs.mkShell {
  buildInputs = with pkgs; [
    # Core
    pacman
    arch-install-scripts

    # Python + parted
    python3
    python3Packages.pyparted

    # Filesystem tools
    dosfstools
    e2fsprogs
    btrfs-progs
    xfsprogs
    f2fs-tools
    cryptsetup
    lvm2

    # Utils
    util-linux
    pciutils
    parted
    zstd
  ];
}
