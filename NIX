# shell.nix
# Usage: nix-shell NIX
{ pkgs ? import <nixpkgs> {} }:

pkgs.mkShell {
  LD_LIBRARY_PATH = "${pkgs.libxcrypt}/lib";

  buildInputs = with pkgs; [
    # Core
    pacman
    arch-install-scripts
    git

    # Python + parted
    (python3.withPackages (ps: [ ps.pyparted ]))

    # Filesystem tools
    dosfstools
    e2fsprogs
    btrfs-progs
    xfsprogs
    f2fs-tools
    cryptsetup
    lvm2

    # Utils
    coreutils
    util-linux
    pciutils
    kbd
    parted
    zstd
    libxcrypt
  ];
}
